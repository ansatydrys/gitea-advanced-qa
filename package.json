{
  "name": "gitea-qa-suite",
  "version": "2.0.0",
  "description": "Automated QA test suite for Gitea 1.25.5 — Assignment 2",
  "scripts": {
    "test": "npx playwright test",
    "test:auth": "npx playwright test auth.spec.ts",
    "test:repo": "npx playwright test repository.spec.ts",
    "test:admin": "npx playwright test admin.spec.ts",
    "test:issues": "npx playwright test issues.spec.ts",
    "test:input": "npx playwright test input-validation.spec.ts",
    "test:users": "npx playwright test user-management.spec.ts",
    "test:git": "npx playwright test git-operations.spec.ts",
    "test:api": "newman run tests/api/gitea_api.postman_collection.json -e tests/api/environment.json --reporters cli,json --reporter-json-export reports/api-results.json",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.0.0",
    "docx": "^9.6.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "newman": "^2.1.2"
  }
}
